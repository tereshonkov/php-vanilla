{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "php-starter/php-starter",
    "type": "project",
    "description": "The skeleton application for PHP native development.",
    "license": "MIT",
    "require": {
        "php": "^8.5"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.68",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "stan": "phpstan analyze",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix",
        "test": "phpunit"
    }
}